<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TSA Bursátil · Simulador de Descuento</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=IBM+Plex+Mono:wght@500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
  :root{
    --navy-950:#04090F;
    --navy-900:#060F1D;
    --navy-850:#081726;
    --navy-800:#0A1C32;
    --navy-700:#0F2540;
    --navy-600:#16304F;
    --navy-line:rgba(140,160,195,.14);
    --gray-100:#F1F1F1;
    --gray-300:#D0D0D0;
    --gray-500:#9A9A9A;
    --ink:#F1F1EF;
    --ink-dim:rgba(241,241,239,.62);
    --ink-faint:rgba(241,241,239,.38);
    --good:#7FBF9E;
    --bad:#D98C7A;
    --white:#FFFFFF;
  }
  *{box-sizing:border-box;}
  body{margin:0;}
  html,body{
    background:var(--navy-950);
    color:var(--ink);
    font-family:'Manrope',sans-serif;
    -webkit-font-smoothing:antialiased;
    min-height:100%;
  }
  .bg-art{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
  .bg-art svg{width:100%;height:100%;}
  .bg-art::after{
    content:"";position:absolute;inset:0;
    background:radial-gradient(120% 90% at 50% 0%, rgba(4,9,15,0) 0%, rgba(4,9,15,.55) 55%, var(--navy-950) 100%);
  }
  .app{max-width:1080px;margin:0 auto;padding:0 20px 70px;position:relative;z-index:1;}

  header.hero{padding:44px 20px 30px;margin:0 -20px;border-bottom:1px solid var(--navy-line);text-align:center;}
  .hero-logo{height:52px;margin-bottom:18px;}
  h1.title{font-family:'Manrope',sans-serif;font-weight:800;font-size:clamp(26px,4.5vw,38px);margin:0 0 8px;letter-spacing:-.01em;}
  .subtitle{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--ink-dim);letter-spacing:.02em;}

  h2.section-title{
    font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.08em;
    color:var(--gray-300);margin:0 0 4px;
  }
  p.section-hint{font-size:13.5px;color:var(--ink-dim);margin:4px 0 16px;}

  .card{background:var(--navy-850);border:1px solid var(--navy-line);border-radius:12px;padding:22px;margin-bottom:22px;box-shadow:0 20px 40px -28px rgba(0,0,0,.7);}
  section.block{padding-top:34px;}

  .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  @media(min-width:680px){.grid.cols-3{grid-template-columns:repeat(3,1fr);}}
  .field{display:flex;flex-direction:column;gap:6px;}
  .field.wide{grid-column:1/-1;}
  .field label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-dim);}
  .field input, .field select{
    font-family:'IBM Plex Mono',monospace;font-size:15px;font-weight:600;
    padding:10px 11px;border:1.5px solid var(--navy-line);border-radius:7px;
    background:var(--navy-900);color:var(--ink);width:100%;color-scheme:dark;
  }
  .field input:focus, .field select:focus{outline:none;border-color:var(--navy-600);}
  .field .hint{font-size:11px;color:var(--ink-faint);}

  .toggle-group{display:flex;gap:8px;background:var(--navy-900);border:1.5px solid var(--navy-line);border-radius:8px;padding:4px;}
  .toggle-group button{
    flex:1;appearance:none;border:none;background:transparent;color:var(--ink-dim);
    font-family:'Manrope',sans-serif;font-weight:700;font-size:13.5px;padding:9px 10px;
    border-radius:5px;cursor:pointer;transition:background .15s, color .15s;
  }
  .toggle-group button.active{background:var(--navy-600);color:var(--white);}

  details.advanced{margin-top:4px;}
  details.advanced summary{cursor:pointer;font-size:13px;color:var(--ink-dim);font-weight:700;list-style:none;padding:6px 0;}
  details.advanced summary::-webkit-details-marker{display:none;}
  details.advanced summary::before{content:"▸ ";color:var(--gray-500);}
  details.advanced[open] summary::before{content:"▾ ";}
  details.advanced .grid{margin-top:14px;}

  .timeline{display:flex;justify-content:space-between;gap:6px;position:relative;padding:10px 0 0;}
  .timeline::before{content:"";position:absolute;top:23px;left:5%;right:5%;height:2px;background:var(--navy-line);}
  .t-stop{flex:1;text-align:center;position:relative;z-index:1;}
  .t-dot{width:12px;height:12px;border-radius:50%;background:var(--navy-600);border:2px solid var(--navy-950);margin:0 auto 10px;}
  .t-label{font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-dim);font-weight:700;margin-bottom:4px;}
  .t-date{font-family:'IBM Plex Mono',monospace;font-size:13.5px;font-weight:600;}
  .t-days{font-size:10.5px;color:var(--gray-500);margin-top:2px;}

  .results-grid{display:grid;grid-template-columns:1fr;gap:20px;}
  @media(min-width:820px){.results-grid{grid-template-columns:1fr 1fr;}}
  .result-card{background:var(--navy-850);border:1px solid var(--navy-line);border-radius:12px;overflow:hidden;box-shadow:0 20px 40px -28px rgba(0,0,0,.7);}
  .result-card.comprador{border-top:3px solid #4C7CB1;}
  .result-card.vendedor{border-top:3px solid var(--gray-300);}
  .result-head{padding:18px 20px 14px;border-bottom:1px solid var(--navy-line);display:flex;align-items:center;gap:10px;}
  .result-head img{height:20px;}
  .result-head .rname{font-weight:800;font-size:14px;letter-spacing:.03em;text-transform:uppercase;}
  .result-body{padding:18px 20px 6px;}
  .rn-big{text-align:center;padding:6px 0 18px;}
  .rn-big .lbl{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-dim);font-weight:700;}
  .rn-big .val{font-family:'IBM Plex Mono',monospace;font-size:34px;font-weight:700;margin-top:4px;}
  .row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--navy-line);font-size:13.5px;}
  .row:last-child{border-bottom:none;}
  .row .k{color:var(--ink-dim);}
  .row .v{font-family:'IBM Plex Mono',monospace;font-weight:600;}
  .row.total .v{font-size:16px;color:var(--white);}
  .row.total{border-top:1.5px solid var(--navy-line);margin-top:4px;padding-top:12px;}
  .result-foot{padding:14px 20px 20px;}
  .dl-btn{
    width:100%;background:transparent;border:1.5px solid var(--navy-600);color:var(--ink);
    font-family:'Manrope',sans-serif;font-weight:700;font-size:13.5px;padding:11px 16px;
    border-radius:8px;cursor:pointer;transition:background .15s;
  }
  .dl-btn:hover{background:var(--navy-700);}

  .holiday-list{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;max-height:180px;overflow-y:auto;padding-right:4px;}
  .holiday-chip{
    display:flex;align-items:center;gap:6px;background:var(--navy-900);border:1px solid var(--navy-line);
    border-radius:6px;padding:6px 10px;font-family:'IBM Plex Mono',monospace;font-size:12.5px;
  }
  .holiday-chip button{border:none;background:none;color:var(--bad);cursor:pointer;font-size:13px;padding:0;line-height:1;}
  .add-holiday-row{display:flex;gap:10px;margin-top:16px;}
  .add-holiday-row input{flex:1;}
  .add-holiday-row button{
    background:var(--navy-600);border:none;color:var(--white);font-weight:700;font-size:13px;
    padding:0 18px;border-radius:7px;cursor:pointer;white-space:nowrap;
  }
  .warning{background:rgba(217,140,122,.12);border:1px solid rgba(217,140,122,.4);color:var(--bad);
    border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:16px;}

  footer.note{text-align:center;font-size:12px;color:var(--ink-faint);margin-top:30px;font-family:'IBM Plex Mono',monospace;}
</style>
</head>
<body>

<div class="bg-art">
  <svg viewBox="0 0 1400 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="base" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#04090F"/>
        <stop offset="100%" stop-color="#060F1D"/>
      </linearGradient>
      <linearGradient id="pDark1" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#060F1D"/>
        <stop offset="100%" stop-color="#020509"/>
      </linearGradient>
      <linearGradient id="pDark2" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0F2540"/>
        <stop offset="100%" stop-color="#060F1D"/>
      </linearGradient>
      <linearGradient id="pGray" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#8A8A8A"/>
        <stop offset="100%" stop-color="#63696E"/>
      </linearGradient>
    </defs>
    <rect width="1400" height="900" fill="url(#base)"/>
    <g opacity="0.9">
      <polygon points="120,560 260,400 340,400 200,560" fill="url(#pDark2)"/>
      <polygon points="230,560 370,400 450,400 310,560" fill="url(#pDark1)"/>
      <polygon points="340,560 480,400 560,400 420,560" fill="url(#pDark2)"/>
    </g>
    <g opacity="0.16">
      <polygon points="980,520 1120,360 1200,360 1060,520" fill="url(#pGray)"/>
      <polygon points="1090,520 1230,360 1310,360 1170,520" fill="url(#pGray)"/>
    </g>
    <g opacity="0.5">
      <polygon points="900,780 1000,660 1060,660 960,780" fill="url(#pDark2)"/>
      <polygon points="985,780 1085,660 1145,660 1045,780" fill="url(#pDark1)"/>
    </g>
  </svg>
</div>

<div class="app">
  <header class="hero">
    <img class="hero-logo" id="logoImg" src="" alt="TSA Bursátil">
    <h1 class="title">Simulador de descuento de valores</h1>
    <div class="subtitle">Cheques de pago diferido (CPD) y pagarés bursátiles</div>
  </header>

  <section class="block">
    <h2 class="section-title">Datos de la operación</h2>
    <p class="section-hint">Completá los datos del instrumento a negociar.</p>
    <div class="card">
      <div class="field wide" style="margin-bottom:18px;">
        <label>Instrumento</label>
        <div class="toggle-group" id="instrumentoToggle">
          <button data-val="CPD" class="active">Cheque de pago diferido (CPD)</button>
          <button data-val="PAGARE">Pagaré bursátil</button>
        </div>
      </div>

      <div class="grid cols-3">
        <div class="field">
          <label for="inpNominal">Importe nominal ($)</label>
          <input type="number" id="inpNominal" value="1000000" step="1000">
        </div>
        <div class="field">
          <label for="inpVencimiento">Fecha de vencimiento</label>
          <input type="date" id="inpVencimiento">
        </div>
        <div class="field">
          <label for="inpConcertacion">Fecha de concertación (T)</label>
          <input type="date" id="inpConcertacion">
        </div>
        <div class="field">
          <label>Plazo de liquidación</label>
          <div class="toggle-group" id="plazoToggle">
            <button data-val="CI" class="active">CI (mismo día)</button>
            <button data-val="24HS">24hs (T+1)</button>
          </div>
        </div>
        <div class="field">
          <label for="inpTasa">Tasa de descuento (% TNA vencida)</label>
          <input type="number" id="inpTasa" value="20" step="0.1">
        </div>
        <div class="field">
          <label for="inpCondicionIva">Condición frente al IVA del comprador</label>
          <select id="inpCondicionIva">
            <option>Responsable Inscripto</option>
            <option>Exento</option>
            <option>Consumidor Final</option>
            <option>Responsable Monotributo</option>
          </select>
        </div>
      </div>

      <details class="advanced">
        <summary>Comisiones y aranceles</summary>
        <div class="grid cols-3">
          <div class="field">
            <label for="inpComTSA">Comisión TSA (% anual)</label>
            <input type="number" id="inpComTSA" value="3" step="0.1">
          </div>
          <div class="field">
            <label for="inpComSGR">Comisión SGR (% anual)</label>
            <input type="number" id="inpComSGR" value="0" step="0.1">
          </div>
          <div class="field">
            <label for="inpIIBB">Ingresos brutos (% s/nominal)</label>
            <input type="number" id="inpIIBB" value="0.005" step="0.001">
          </div>
          <div class="field">
            <label for="inpDerechos">Derechos de mercado (% s/90 días)</label>
            <input type="number" id="inpDerechos" value="0.06" step="0.01">
          </div>
        </div>
      </details>
    </div>
  </section>

  <section class="block">
    <h2 class="section-title">Cronología de la operación</h2>
    <p class="section-hint">Fecha de pago según instrumento: CPD = vencimiento + 2 días hábiles · Pagaré = vencimiento + 1 día hábil.</p>
    <div class="card">
      <div id="warningBox"></div>
      <div class="timeline" id="timeline"></div>
    </div>
  </section>

  <section class="block">
    <h2 class="section-title">Resultado de la operación</h2>
    <p class="section-hint">Vista para cada punta de la negociación.</p>
    <div class="results-grid">
      <div class="result-card comprador" id="cardComprador">
        <div class="result-head"><img src="" id="logoMiniComprador" alt=""><span class="rname">Comprador</span></div>
        <div class="result-body" id="bodyComprador"></div>
        <div class="result-foot"><button class="dl-btn" id="btnDlComprador">Descargar resumen (imagen)</button></div>
      </div>
      <div class="result-card vendedor" id="cardVendedor">
        <div class="result-head"><img src="" id="logoMiniVendedor" alt=""><span class="rname">Vendedor</span></div>
        <div class="result-body" id="bodyVendedor"></div>
        <div class="result-foot"><button class="dl-btn" id="btnDlVendedor">Descargar resumen (imagen)</button></div>
      </div>
    </div>
  </section>

  <section class="block">
    <h2 class="section-title">Feriados</h2>
    <p class="section-hint">Se usan para calcular días hábiles (liquidación 24hs y fecha de pago). Precargamos un calendario 2026 de referencia — revisalo y ajustalo, ya que los feriados puente se confirman año a año.</p>
    <div class="card">
      <div class="add-holiday-row">
        <input type="date" id="inpNewHoliday">
        <button id="btnAddHoliday">+ Agregar feriado</button>
      </div>
      <div class="holiday-list" id="holidayList"></div>
    </div>
  </section>

  <footer class="note">TSA BURSÁTIL · SIMULADOR DE NEGOCIACIÓN DE VALORES</footer>
</div>

<script>
const LOGO_SRC = "data:image/png;base64,";
document.getElementById('logoImg').src = LOGO_SRC;
document.getElementById('logoMiniComprador').src = LOGO_SRC;
document.getElementById('logoMiniVendedor').src = LOGO_SRC;

const HOLIDAYS_KEY = 'tsa_holidays_v1';
const DEFAULT_HOLIDAYS_2026 = [
  '2026-01-01','2026-02-16','2026-02-17','2026-03-23','2026-03-24',
  '2026-04-02','2026-04-03','2026-05-01','2026-05-25','2026-06-15',
  '2026-06-20','2026-07-09','2026-07-10','2026-08-17','2026-10-12',
  '2026-11-23','2026-12-07','2026-12-08','2026-12-25'
];

function loadHolidays(){
  try{
    const raw = localStorage.getItem(HOLIDAYS_KEY);
    if(!raw) return [...DEFAULT_HOLIDAYS_2026];
    return JSON.parse(raw);
  }catch(e){ return [...DEFAULT_HOLIDAYS_2026]; }
}
function saveHolidays(){ localStorage.setItem(HOLIDAYS_KEY, JSON.stringify(holidays)); }

let holidays = loadHolidays();

const state = {
  instrumento: 'CPD',
  plazo: 'CI'
};

function toISO(d){
  const y=d.getFullYear(), m=String(d.getMonth()+1).padStart(2,'0'), day=String(d.getDate()).padStart(2,'0');
  return `${y}-${m}-${day}`;
}
function fromISO(s){
  const [y,m,d] = s.split('-').map(Number);
  return new Date(y, m-1, d);
}
function isHoliday(date){
  const dow = date.getDay();
  if(dow===0 || dow===6) return true;
  return holidays.includes(toISO(date));
}
function addBusinessDays(date, n){
  let d = new Date(date);
  let added = 0;
  while(added < n){
    d.setDate(d.getDate()+1);
    if(!isHoliday(d)) added++;
  }
  return d;
}
function diffDays(a,b){ return Math.round((b-a)/86400000); }
function fmtDate(d){
  return d.toLocaleDateString('es-AR', {day:'2-digit', month:'2-digit', year:'numeric'});
}
function fmtMoney(v){
  return '$ ' + Math.round(v).toLocaleString('es-AR');
}
function fmtPct(v){
  return (v*100).toFixed(2) + '%';
}

// ---------- toggles ----------
document.getElementById('instrumentoToggle').addEventListener('click', (e)=>{
  const btn = e.target.closest('button'); if(!btn) return;
  state.instrumento = btn.dataset.val;
  document.querySelectorAll('#instrumentoToggle button').forEach(b=>b.classList.toggle('active', b===btn));
  calc();
});
document.getElementById('plazoToggle').addEventListener('click', (e)=>{
  const btn = e.target.closest('button'); if(!btn) return;
  state.plazo = btn.dataset.val;
  document.querySelectorAll('#plazoToggle button').forEach(b=>b.classList.toggle('active', b===btn));
  calc();
});

// ---------- inputs ----------
const ids = ['inpNominal','inpVencimiento','inpConcertacion','inpTasa','inpCondicionIva','inpComTSA','inpComSGR','inpIIBB','inpDerechos'];
ids.forEach(id=>{
  document.getElementById(id).addEventListener('input', calc);
  document.getElementById(id).addEventListener('change', calc);
});

// ---------- defaults ----------
(function setDefaults(){
  const today = new Date();
  const venc = new Date(today); venc.setDate(venc.getDate()+30);
  document.getElementById('inpConcertacion').value = toISO(today);
  document.getElementById('inpVencimiento').value = toISO(venc);
})();

// ---------- holidays UI ----------
function renderHolidays(){
  const list = document.getElementById('holidayList');
  const sorted = [...holidays].sort();
  list.innerHTML = sorted.map(h => `
    <div class="holiday-chip">
      <span>${fmtDate(fromISO(h))}</span>
      <button data-h="${h}" title="Eliminar">✕</button>
    </div>
  `).join('');
  list.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click', ()=>{
      holidays = holidays.filter(h=>h!==b.dataset.h);
      saveHolidays();
      renderHolidays();
      calc();
    });
  });
}
document.getElementById('btnAddHoliday').addEventListener('click', ()=>{
  const v = document.getElementById('inpNewHoliday').value;
  if(!v) return;
  if(!holidays.includes(v)){
    holidays.push(v);
    saveHolidays();
    renderHolidays();
    calc();
  }
  document.getElementById('inpNewHoliday').value = '';
});
renderHolidays();

// ---------- core calc ----------
function calc(){
  const warningBox = document.getElementById('warningBox');
  warningBox.innerHTML = '';

  const nominal = parseFloat(document.getElementById('inpNominal').value) || 0;
  const vencIso = document.getElementById('inpVencimiento').value;
  const concIso = document.getElementById('inpConcertacion').value;
  const tasaTNA = (parseFloat(document.getElementById('inpTasa').value) || 0) / 100;
  const condicionIva = document.getElementById('inpCondicionIva').value;
  const comTSA = (parseFloat(document.getElementById('inpComTSA').value) || 0) / 100;
  const comSGR = (parseFloat(document.getElementById('inpComSGR').value) || 0) / 100;
  const iibb = (parseFloat(document.getElementById('inpIIBB').value) || 0) / 100;
  const derechos = (parseFloat(document.getElementById('inpDerechos').value) || 0) / 100;

  if(!vencIso || !concIso){ renderTimeline(null); return; }

  const concertacion = fromISO(concIso);
  const vencimiento = fromISO(vencIso);

  const liquidacion = state.plazo === 'CI' ? concertacion : addBusinessDays(concertacion, 1);
  const pagoN = state.instrumento === 'CPD' ? 2 : 1;
  const pago = addBusinessDays(vencimiento, pagoN);
  const dias = diffDays(liquidacion, pago);

  renderTimeline({concertacion, liquidacion, vencimiento, pago, dias});

  if(dias <= 0){
    warningBox.innerHTML = '<div class="warning">La fecha de vencimiento debe ser posterior a la fecha de liquidación para poder calcular una tasa.</div>';
    document.getElementById('bodyComprador').innerHTML = '';
    document.getElementById('bodyVendedor').innerHTML = '';
    return;
  }

  const VD = nominal / (1 + tasaTNA/365*dias);
  const intereses = nominal - VD;

  // Comprador
  const gastosNeg = nominal * comTSA/365*dias;
  const ivaGastosComprador = gastosNeg * 0.21;
  const montoNetoAPagar = VD + gastosNeg + ivaGastosComprador;
  const rendimiento = (nominal/montoNetoAPagar - 1) * 365/dias;

  // Vendedor
  const comisionTSAv = VD * comTSA/365*dias;
  const comisionSGRv = nominal * comSGR/365*dias;
  const ingresosBrutos = nominal * iibb;
  const derechosMercado = VD * derechos * dias/90;
  const ivaGastosVendedor = (comisionTSAv + comisionSGRv + derechosMercado) * 0.21;
  const montoNetoDeGastos = VD - comisionTSAv - comisionSGRv - ingresosBrutos - derechosMercado - ivaGastosVendedor;

  const noIvaInteres = (state.instrumento === 'PAGARE') ||
    (condicionIva === 'Exento' || condicionIva === 'Consumidor Final' || condicionIva === 'Responsable Monotributo');
  const ivaSobreIntereses = noIvaInteres ? 0 : intereses * 0.21;
  const montoAPercibir = montoNetoDeGastos - ivaSobreIntereses;
  const costoNeto = (nominal/montoAPercibir - 1) * 365/dias;

  const ahorroImpDebCred = montoNetoDeGastos * 0.006;
  const ahorroAnualizado = ahorroImpDebCred/nominal/dias*365;

  document.getElementById('bodyComprador').innerHTML = `
