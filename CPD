function renderTimeline(d){
  const el = document.getElementById('timeline');
  if(!d){ el.innerHTML=''; return; }
  el.innerHTML = `
    <div class="t-stop"><div class="t-dot"></div><div class="t-label">Concertación (T)</div><div class="t-date">${fmtDate(d.concertacion)}</div></div>
    <div class="t-stop"><div class="t-dot"></div><div class="t-label">Liquidación</div><div class="t-date">${fmtDate(d.liquidacion)}</div></div>
    <div class="t-stop"><div class="t-dot"></div><div class="t-label">Vencimiento</div><div class="t-date">${fmtDate(d.vencimiento)}</div></div>
    <div class="t-stop"><div class="t-dot"></div><div class="t-label">Pago instrumento</div><div class="t-date">${fmtDate(d.pago)}</div><div class="t-days">${d.dias} días desde liquidación</div></div>
  `;
}

// ---------- image export ----------
async function downloadCard(elId, filename){
  const el = document.getElementById(elId);
  const canvas = await html2canvas(el, {backgroundColor:'#0D2138', scale:2, useCORS:true, logging:false});
  const link = document.createElement('a');
  link.download = filename;
  link.href = canvas.toDataURL('image/png');
  link.click();
}
document.getElementById('btnDlComprador').addEventListener('click', ()=>downloadCard('cardComprador','tsa_resumen_comprador.png'));
document.getElementById('btnDlVendedor').addEventListener('click', ()=>downloadCard('cardVendedor','tsa_resumen_vendedor.png'));

calc();
</script>
